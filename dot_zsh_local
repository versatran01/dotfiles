# Set up Homebrew based on OS. `brew shellenv` exports $HOMEBREW_PREFIX et al.
if [[ "$OSTYPE" == darwin* ]]; then
  # macOS: Apple Silicon at /opt/homebrew, Intel at /usr/local
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
else
  # Linux (Ubuntu): Linuxbrew
  if [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  fi
fi
export EDITOR=nvim

command -v fzf >/dev/null && eval "$(fzf --zsh)"
[ -f ~/.cargo/env ] && source ~/.cargo/env
[ -f ~/.bash_aliases ] && source ~/.bash_aliases
[ -f ~/.fzf-git.sh/fzf-git.sh ] && source ~/.fzf-git.sh/fzf-git.sh

# history
HISTSIZE=10000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
setopt append_history
setopt extended_history
setopt share_history
setopt hist_ignore_space
setopt hist_ignore_dups
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_find_no_dups
setopt hist_expire_dups_first
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward

# fzf preview — Debian/Ubuntu ship `bat` as `batcat`, so pick whichever exists.
if command -v bat >/dev/null; then
  BAT_BIN=bat
elif command -v batcat >/dev/null; then
  BAT_BIN=batcat
else
  BAT_BIN=cat
fi
export FZF_CTRL_T_OPTS="--preview '$BAT_BIN -n --color=always --line-range :500 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

_fzf_comprun() {
  local command=$1
  shift

  case "$command" in
  cd) fzf --preview 'eza --tree --color=always {} | head -200' "$@" ;;
  export | unset) fzf --preview "eval 'echo $'{}" "$@" ;;
  ssh) fzf --preview 'dig {}' "$@" ;;
  *) fzf --preview "$BAT_BIN -n --color=always --line-range :500 {}" "$@" ;;
  esac
}

# starship
export STARSHIP_CONFIG=~/.config/starship.toml
command -v starship >/dev/null && eval "$(starship init zsh)"

# zoxide
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

# yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

if type brew &>/dev/null; then
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
fi

autoload -Uz compinit
# Regenerate the completion dump at most once a day; otherwise load it with -C
# (skips the slow security check, making shell startup noticeably faster).
() {
  local dump=( ${ZDOTDIR:-$HOME}/.zcompdump(N.mh+24) )
  if (( $#dump )); then
    compinit
  else
    compinit -C
  fi
}

[ -f "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] \
  && source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
# Note: zsh-syntax-highlighting must be sourced last.
[ -f "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ] \
  && source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
