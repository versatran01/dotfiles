// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never"
  },
  "show_whitespaces": "trailing",
  "wrap_guides": [
    120
  ],
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "which_key": {
    "enabled": false
  },
  "autosave": "on_focus_change",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha"
  },
  "semantic_tokens": "combined",
  "edit_predictions": {
    "provider": "copilot",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark"
  },
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_font_family": "Iosevka Nerd Font",
  "vim_mode": true,
  "tab_bar": {
    "show": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.cache",
    "**/.settings",
    "**/.mypy_cache",
    "**/.pytest_cache",
    "**/*cache__",
  ],
}
